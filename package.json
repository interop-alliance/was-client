{
  "name": "@interop/was-client",
  "description": "A developer-friendly client for Wallet Attached Storage (WAS) servers.",
  "version": "0.10.0",
  "type": "module",
  "scripts": {
    "build": "pnpm run clear && tsc",
    "clear": "rimraf dist/*",
    "dev": "vite",
    "fix": "eslint --fix src test && pnpm run format",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"*.md\"",
    "lint": "eslint src test",
    "prepare": "pnpm run build",
    "rebuild": "pnpm run clear && pnpm run build",
    "test": "pnpm run fix && pnpm run lint && pnpm run test:node && pnpm run test:browser",
    "test:browser": "playwright test",
    "test:node": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "react-native": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./edv": {
      "types": "./dist/edv/index.d.ts",
      "react-native": "./dist/edv/index.js",
      "import": "./dist/edv/index.js",
      "default": "./dist/edv/index.js"
    }
  },
  "module": "dist/index.js",
  "browser": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "dependencies": {
    "@interop/data-integrity-core": "^8.1.0",
    "@interop/ed25519-signature": "^7.1.3",
    "@interop/edv-client": "^17.3.1",
    "@interop/ezcap": "^7.3.2",
    "@interop/http-client": "^1.0.4",
    "@interop/storage-core": "^0.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@interop/ed25519-verification-key": "^8.0.2",
    "@interop/x25519-key-agreement-key": "^5.1.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "wallet attached storage",
    "was",
    "zcap",
    "ezcap"
  ],
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=24.0"
  },
  "author": {
    "name": "Interop Alliance",
    "url": "https://github.com/interop-alliance/"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/interop-alliance/was-client.git"
  },
  "homepage": "https://github.com/interop-alliance/was-client",
  "bugs": "https://github.com/interop-alliance/was-client/issues"
}
